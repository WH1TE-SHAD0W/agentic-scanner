        "metabolic_syndrome": { "type": "integer", "nullable": true },
        "ichs": { "type": "integer", "nullable": true },
        "prior_mi": { "type": "integer", "nullable": true },
        "ckd": { "type": "integer", "nullable": true },
        "copd": { "type": "integer", "nullable": true },
        "oncology_history": { "type": "integer", "nullable": true },
        "chemotherapy": { "type": "integer", "nullable": true }
